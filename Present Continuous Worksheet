<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>A1 Worksheet: Present Continuous</title>
    <style>
        * {
            box-sizing: border-box;
        }
        body {
            background-color: #f0f7ff;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 20px;
            display: flex;
            justify-content: center;
        }
        .worksheet {
            max-width: 1000px;
            width: 100%;
            background: white;
            border-radius: 28px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            padding: 30px 35px;
            transition: all 0.2s;
        }
        h1 {
            font-size: 1.9rem;
            color: #1e466e;
            border-left: 8px solid #ffb347;
            padding-left: 18px;
            margin-top: 0;
            margin-bottom: 5px;
        }
        .sub {
            color: #4a627a;
            border-bottom: 2px solid #ffe0b5;
            padding-bottom: 12px;
            margin-bottom: 28px;
            font-style: italic;
        }
        .task {
            background: #fefaf5;
            margin-bottom: 32px;
            border-radius: 24px;
            padding: 18px 22px;
            box-shadow: 0 2px 6px rgba(0,0,0,0.05);
            border: 1px solid #ffe2c4;
        }
        .task-title {
            font-weight: bold;
            font-size: 1.3rem;
            background: #ffedd5;
            display: inline-block;
            padding: 4px 18px;
            border-radius: 40px;
            margin-bottom: 18px;
            color: #a4511b;
        }
        .question {
            margin: 15px 0;
            line-height: 1.6;
        }
        .inline-gap {
            display: inline-block;
            margin: 0 5px;
        }
        .inline-gap input {
            width: 140px;
            padding: 5px 10px;
            border-radius: 20px;
            border: 1px solid #ffb347;
            background: #fffef7;
            font-family: inherit;
            font-size: 0.9rem;
            text-align: center;
        }
        .inline-gap input:focus {
            outline: none;
            border-color: #ff8c00;
            background: #fff8e7;
        }
        .verb-bank {
            background: #eef2fa;
            padding: 10px 16px;
            border-radius: 20px;
            display: inline-block;
            margin-bottom: 12px;
            font-size: 0.9rem;
        }
        .rule-box {
            background: #e8f4f8;
            padding: 10px 16px;
            border-radius: 16px;
            margin: 10px 0;
            font-size: 0.9rem;
            border-left: 4px solid #ffb347;
        }
        .formula {
            background: #fff0d4;
            padding: 12px 20px;
            border-radius: 30px;
            text-align: center;
            font-size: 1.1rem;
            font-weight: bold;
            margin-bottom: 20px;
            font-family: monospace;
        }
        button {
            background-color: #ffb347;
            border: none;
            padding: 12px 28px;
            font-size: 1rem;
            font-weight: bold;
            border-radius: 40px;
            cursor: pointer;
            margin-top: 12px;
            margin-right: 15px;
            transition: 0.1s;
            color: #2d3e50;
        }
        button:hover {
            background-color: #ff9f1a;
            transform: scale(0.98);
        }
        .answers {
            background: #e9f3e6;
            padding: 18px 22px;
            border-radius: 24px;
            margin-top: 20px;
            border-left: 8px solid #6fbf4c;
            display: none;
        }
        .answers.show {
            display: block;
        }
        .good {
            color: #2d6a4f;
            font-weight: bold;
        }
        footer {
            text-align: center;
            font-size: 0.8rem;
            color: gray;
            margin-top: 20px;
        }
        hr {
            margin: 20px 0;
        }
        .small-icon {
            font-size: 1.2rem;
        }
        @media (max-width: 650px) {
            .worksheet { padding: 18px; }
            .inline-gap input { width: 110px; }
        }
    </style>
</head>
<body>
<div class="worksheet">
    <h1>✨ Present Continuous ✨</h1>
    <div class="sub">A1 Worksheet · am / is / are + verb-ing · Actions happening NOW</div>

    <!-- FORMULA REMINDER -->
    <div class="formula">
        📝 FORMULA: <strong style="color:#ff8c00;">am / is / are</strong> + <strong style="color:#2d6a4f;">verb + -ing</strong>
    </div>

    <!-- TASK 1: am/is/are -->
    <div class="task">
        <div class="task-title">📘 Task 1: Choose am / is / are</div>
        <div>🔹 Fill in the correct form of <strong>am / is / are</strong>:</div>
        <div class="question">1. I <span class="inline-gap"><input type="text" id="t1q1" placeholder="am/is/are" size="6"></span> reading a comic book.</div>
        <div class="question">2. She <span class="inline-gap"><input type="text" id="t1q2" placeholder="am/is/are" size="6"></span> dancing in the kitchen.</div>
        <div class="question">3. They <span class="inline-gap"><input type="text" id="t1q3" placeholder="am/is/are" size="6"></span> playing football.</div>
        <div class="question">4. He <span class="inline-gap"><input type="text" id="t1q4" placeholder="am/is/are" size="6"></span> sleeping on the sofa.</div>
        <div class="question">5. We <span class="inline-gap"><input type="text" id="t1q5" placeholder="am/is/are" size="6"></span> learning English.</div>
        <div class="question">6. It <span class="inline-gap"><input type="text" id="t1q6" placeholder="am/is/are" size="6"></span> raining outside.</div>
    </div>

    <!-- TASK 2: Make positive sentences -->
    <div class="task">
        <div class="task-title">✏️ Task 2: Make sentences</div>
        <div>🔹 Write the full Present Continuous sentence:</div>
        <div class="question">a) Emma / wear / a yellow dress → <span class="inline-gap"><input type="text" id="t2a" placeholder="write sentence" size="45"></span></div>
        <div class="question">b) the cat / drink / milk → <span class="inline-gap"><input type="text" id="t2b" placeholder="write sentence" size="45"></span></div>
        <div class="question">c) my friends / swim / in the pool → <span class="inline-gap"><input type="text" id="t2c" placeholder="write sentence" size="45"></span></div>
        <div class="question">d) I / write / an email → <span class="inline-gap"><input type="text" id="t2d" placeholder="write sentence" size="45"></span></div>
    </div>

    <!-- TASK 3: Negative sentences -->
    <div class="task">
        <div class="task-title">🚫 Task 3: Make negative</div>
        <div>🔹 Make negative sentences (isn't / aren't / 'm not):</div>
        <div class="question">1. Tom is eating a burger. → Tom <span class="inline-gap"><input type="text" id="t3q1" placeholder="isn't eating" size="20"></span> a burger.</div>
        <div class="question">2. We are watching TV. → We <span class="inline-gap"><input type="text" id="t3q2" placeholder="aren't watching" size="20"></span> TV.</div>
        <div class="question">3. I am sleeping. → I <span class="inline-gap"><input type="text" id="t3q3" placeholder="am not sleeping" size="20"></span>.</div>
        <div class="question">4. The birds are singing. → The birds <span class="inline-gap"><input type="text" id="t3q4" placeholder="aren't singing" size="20"></span>.</div>
    </div>

    <!-- TASK 4: Write affirmative sentences (CONSTRUCT Present Continuous) -->
    <div class="task">
        <div class="task-title">📝 Task 4: Write affirmative sentences</div>
        <div>🔹 Use the words to make <strong>Present Continuous</strong> sentences ( + ).</div>
        
        <div class="question">
            <span class="small-icon">📌</span> 1. (she / read / a magazine) <br>
            → <span class="inline-gap"><input type="text" id="t4a" placeholder="She is reading..." size="45"></span>
        </div>
        
        <div class="question">
            <span class="small-icon">📌</span> 2. (they / play / basketball) <br>
            → <span class="inline-gap"><input type="text" id="t4b" placeholder="They are playing..." size="45"></span>
        </div>
        
        <div class="question">
            <span class="small-icon">📌</span> 3. (he / eat / an apple) <br>
            → <span class="inline-gap"><input type="text" id="t4c" placeholder="He is eating..." size="45"></span>
        </div>
        
        <div class="question">
            <span class="small-icon">📌</span> 4. (we / watch / a movie) <br>
            → <span class="inline-gap"><input type="text" id="t4d" placeholder="We are watching..." size="45"></span>
        </div>
        
        <div class="question">
            <span class="small-icon">📌</span> 5. (I / learn / English) <br>
            → <span class="inline-gap"><input type="text" id="t4e" placeholder="I am learning..." size="45"></span>
        </div>
        
        <div class="question">
            <span class="small-icon">📌</span> 6. (the dog / run / in the park) <br>
            → <span class="inline-gap"><input type="text" id="t4f" placeholder="The dog is running..." size="45"></span>
        </div>
    </div>

    <!-- TASK 5: Choose correct verb+ing from box -->
    <div class="task">
        <div class="task-title">✅ Task 5: Complete the sentences</div>
        <div class="verb-bank">📦 cooking · running · laughing · drawing · singing · dancing · eating · sleeping</div>
        <div class="question">a) Look! The baby is <span class="inline-gap"><input type="text" id="t5a" placeholder="verb+ing" size="12"></span> happily.</div>
        <div class="question">b) Mom is <span class="inline-gap"><input type="text" id="t5b" placeholder="verb+ing" size="12"></span> soup.</div>
        <div class="question">c) The children are <span class="inline-gap"><input type="text" id="t5c" placeholder="verb+ing" size="12"></span> around the garden.</div>
        <div class="question">d) Anna is <span class="inline-gap"><input type="text" id="t5d" placeholder="verb+ing" size="12"></span> a picture.</div>
        <div class="question">e) My sister is <span class="inline-gap"><input type="text" id="t5e" placeholder="verb+ing" size="12"></span> her favourite song.</div>
    </div>

    <!-- TASK 6: Add -ing to verbs -->
    <div class="task">
        <div class="task-title">➕ Task 6: Add -ing to the verb</div>
        <div class="rule-box">
            📖 <strong>Spelling rules:</strong><br>
            • Most verbs: just add <strong>-ing</strong> (eat → eating)<br>
            • Verbs ending in -e: remove -e, add <strong>-ing</strong> (dance → dancing)<br>
            • Short verbs (CVC): double the last letter + <strong>-ing</strong> (run → running)
        </div>
        <div class="question">1. play → <span class="inline-gap"><input type="text" id="t6a" placeholder="verb+ing" size="15"></span></div>
        <div class="question">2. dance → <span class="inline-gap"><input type="text" id="t6b" placeholder="verb+ing" size="15"></span></div>
        <div class="question">3. run → <span class="inline-gap"><input type="text" id="t6c" placeholder="verb+ing" size="15"></span></div>
        <div class="question">4. write → <span class="inline-gap"><input type="text" id="t6d" placeholder="verb+ing" size="15"></span></div>
        <div class="question">5. swim → <span class="inline-gap"><input type="text" id="t6e" placeholder="verb+ing" size="15"></span></div>
        <div class="question">6. eat → <span class="inline-gap"><input type="text" id="t6f" placeholder="verb+ing" size="15"></span></div>
        <div class="question">7. sit → <span class="inline-gap"><input type="text" id="t6g" placeholder="verb+ing" size="15"></span></div>
        <div class="question">8. read → <span class="inline-gap"><input type="text" id="t6h" placeholder="verb+ing" size="15"></span></div>
    </div>

    <!-- TASK 7: Error correction -->
    <div class="task">
        <div class="task-title">🔧 Task 7: Correct the mistakes</div>
        <div>🔹 Find and correct the mistake:</div>
        <div class="question">1. He are playing video games. → <span class="inline-gap"><input type="text" id="t7a" placeholder="correct sentence" size="40"></span></div>
        <div class="question">2. I is eating an apple. → <span class="inline-gap"><input type="text" id="t7b" placeholder="correct sentence" size="40"></span></div>
        <div class="question">3. They am running fast. → <span class="inline-gap"><input type="text" id="t7c" placeholder="correct sentence" size="40"></span></div>
        <div class="question">4. She not sleeping now. → <span class="inline-gap"><input type="text" id="t7d" placeholder="correct sentence" size="40"></span></div>
        <div class="question">5. We are cook dinner. → <span class="inline-gap"><input type="text" id="t7e" placeholder="correct sentence" size="40"></span></div>
    </div>

    <div style="display: flex; gap: 15px; flex-wrap: wrap;">
        <button id="checkBtn">✅ Check my answers</button>
        <button id="resetBtn">🔄 Clear all</button>
    </div>

    <div id="answerKey" class="answers">
        <strong>📋 RESULTS & ANSWER KEY</strong><br>
        <div id="keyContent"></div>
    </div>
    <footer>⭐ Present Continuous = am/is/are + verb-ing (actions happening now, at this moment)</footer>
</div>

<script>
    // CORRECT ANSWERS + MANY VARIATIONS
    const answers = {
        t1: ["am", "is", "are", "is", "are", "is"],
        t2: [
            "Emma is wearing a yellow dress.",
            "The cat is drinking milk.",
            "My friends are swimming in the pool.",
            "I am writing an email."
        ],
        t3: ["isn't eating", "aren't watching", "am not sleeping", "aren't singing"],
        t4: [
            "She is reading a magazine.",
            "They are playing basketball.",
            "He is eating an apple.",
            "We are watching a movie.",
            "I am learning English.",
            "The dog is running in the park."
        ],
        t5: ["laughing", "cooking", "running", "drawing", "singing"],
        t6: ["playing", "dancing", "running", "writing", "swimming", "eating", "sitting", "reading"],
        t7: [
            "He is playing video games.",
            "I am eating an apple.",
            "They are running fast.",
            "She is not sleeping now.",
            "We are cooking dinner."
        ]
    };

    // Extra variations for flexible checking
    const variations = {
        t3: {
            "isn't eating": ["is not eating"],
            "aren't watching": ["are not watching"],
            "am not sleeping": ["i'm not sleeping"],
            "aren't singing": ["are not singing"]
        },
        t4: {
            "She is reading a magazine.": ["She's reading a magazine."],
            "They are playing basketball.": ["They're playing basketball."],
            "He is eating an apple.": ["He's eating an apple."],
            "We are watching a movie.": ["We're watching a movie."],
            "I am learning English.": ["I'm learning English."],
            "The dog is running in the park.": ["The dog's running in the park."]
        },
        t7: {
            "He is playing video games.": ["He's playing video games."],
            "I am eating an apple.": ["I'm eating an apple."],
            "They are running fast.": ["They're running fast."],
            "She is not sleeping now.": ["She isn't sleeping now.", "She's not sleeping now."],
            "We are cooking dinner.": ["We're cooking dinner."]
        },
        t2: {
            "Emma is wearing a yellow dress.": ["Emma's wearing a yellow dress."],
            "The cat is drinking milk.": ["The cat's drinking milk."],
            "My friends are swimming in the pool.": ["My friends're swimming in the pool."],
            "I am writing an email.": ["I'm writing an email."]
        }
    };

    function normalize(str) {
        return str.trim().toLowerCase().replace(/[.!?]$/, '').replace(/\s+/g, ' ').trim();
    }

    function isAnswerCorrect(userAnswer, correctAnswer, taskType, index) {
        let userNorm = normalize(userAnswer);
        let correctNorm = normalize(correctAnswer);
        
        if (userNorm === correctNorm) return true;
        
        if (taskType === 't3' && variations.t3[correctAnswer]) {
            for (let varAns of variations.t3[correctAnswer]) {
                if (userNorm === normalize(varAns)) return true;
            }
        }
        if (taskType === 't4' && variations.t4[correctAnswer]) {
            for (let varAns of variations.t4[correctAnswer]) {
                if (userNorm === normalize(varAns)) return true;
            }
        }
        if (taskType === 't7' && variations.t7[correctAnswer]) {
            for (let varAns of variations.t7[correctAnswer]) {
                if (userNorm === normalize(varAns)) return true;
            }
        }
        if (taskType === 't2' && variations.t2[correctAnswer]) {
            for (let varAns of variations.t2[correctAnswer]) {
                if (userNorm === normalize(varAns)) return true;
            }
        }
        return false;
    }

    function checkTasks() {
        let score = 0;
        let total = 0;
        let feedback = "";

        // Task 1
        for (let i = 1; i <= 6; i++) {
            let val = document.getElementById(`t1q${i}`).value.trim().toLowerCase();
            let correct = answers.t1[i-1];
            total++;
            if (val === correct) score++;
            else feedback += `Task 1, Q${i}: "${val}" ❌ correct: "${correct}"\n`;
        }

        // Task 2
        for (let i = 0; i < answers.t2.length; i++) {
            let val = document.getElementById(`t2${String.fromCharCode(97+i)}`).value;
            let correct = answers.t2[i];
            total++;
            if (isAnswerCorrect(val, correct, 't2', i)) score++;
            else feedback += `Task 2, ${String.fromCharCode(97+i)}): "${val}" ❌ correct: "${correct}"\n`;
        }

        // Task 3
        for (let i = 1; i <= 4; i++) {
            let val = document.getElementById(`t3q${i}`).value;
            let correct = answers.t3[i-1];
            total++;
            if (isAnswerCorrect(val, correct, 't3', i-1)) score++;
            else feedback += `Task 3, Q${i}: "${val}" ❌ correct: "${correct}"\n`;
        }

        // Task 4 (6 affirmative sentences)
        for (let i = 0; i < answers.t4.length; i++) {
            let val = document.getElementById(`t4${String.fromCharCode(97+i)}`).value;
            let correct = answers.t4[i];
            total++;
            if (isAnswerCorrect(val, correct, 't4', i)) score++;
            else feedback += `Task 4, ${i+1}: "${val}" ❌ correct: "${correct}"\n`;
        }

        // Task 5
        for (let i = 0; i < answers.t5.length; i++) {
            let val = document.getElementById(`t5${String.fromCharCode(97+i)}`).value.trim().toLowerCase();
            let correct = answers.t5[i];
            total++;
            if (val === correct) score++;
            else feedback += `Task 5, ${String.fromCharCode(97+i)}): "${val}" ❌ correct: "${correct}"\n`;
        }

        // Task 6
        for (let i = 0; i < answers.t6.length; i++) {
            let val = document.getElementById(`t6${String.fromCharCode(97+i)}`).value.trim().toLowerCase();
            let correct = answers.t6[i];
            total++;
            if (val === correct) score++;
            else feedback += `Task 6, ${i+1}: "${val}" ❌ correct: "${correct}"\n`;
        }

        // Task 7
        for (let i = 0; i < answers.t7.length; i++) {
            let val = document.getElementById(`t7${String.fromCharCode(97+i)}`).value;
            let correct = answers.t7[i];
            total++;
            if (isAnswerCorrect(val, correct, 't7', i)) score++;
            else feedback += `Task 7, ${String.fromCharCode(97+i)}): "${val}" ❌ correct: "${correct}"\n`;
        }

        let percentage = Math.round((score/total)*100);
        let keyDiv = document.getElementById("keyContent");
        keyDiv.innerHTML = `<strong class="good">Your score: ${score} / ${total} (${percentage}%)</strong><br><br>`;
        
        if (feedback !== "") {
            keyDiv.innerHTML += `<span style="white-space: pre-line; font-size: 0.9rem;">${feedback}</span><br><hr>`;
        } else {
            keyDiv.innerHTML += `🎉🎉 PERFECT! Excellent work! 🎉🎉<br><hr>`;
        }
        
        keyDiv.innerHTML += `
            <b>📌 ANSWER KEY:</b><br><br>
            <b>Task 1:</b> 1.am &nbsp; 2.is &nbsp; 3.are &nbsp; 4.is &nbsp; 5.are &nbsp; 6.is <br>
            <b>Task 2:</b> ${answers.t2.join(" | ")}<br>
            <b>Task 3:</b> ${answers.t3.join(" | ")}<br>
            <b>Task 4 (Affirmative sentences):</b><br>
            &nbsp;&nbsp;1. ${answers.t4[0]}<br>
            &nbsp;&nbsp;2. ${answers.t4[1]}<br>
            &nbsp;&nbsp;3. ${answers.t4[2]}<br>
            &nbsp;&nbsp;4. ${answers.t4[3]}<br>
            &nbsp;&nbsp;5. ${answers.t4[4]}<br>
            &nbsp;&nbsp;6. ${answers.t4[5]}<br>
            <b>Task 5:</b> ${answers.t5.join(" · ")}<br>
            <b>Task 6 (-ing forms):</b> ${answers.t6.join(" · ")}<br>
            <b>Task 7:</b> ${answers.t7.join(" ; ")}<br>
            <hr>
            <i>💡 Remember: am/is/are + verb-ing! (I am, you/we/they are, he/she/it is)</i>
        `;
        document.getElementById("answerKey").classList.add("show");
    }

    function resetAll() {
        const inputs = document.querySelectorAll('input');
        inputs.forEach(input => input.value = '');
        document.getElementById("answerKey").classList.remove("show");
    }

    document.getElementById("checkBtn").addEventListener("click", checkTasks);
    document.getElementById("resetBtn").addEventListener("click", resetAll);
</script>
</body>
</html>
